# Copier ce fichier en .env et remplir les valeurs réelles.
# Ces variables doivent être exportées dans l'environnement du WSGI sur PythonAnywhere.

DJANGO_SECRET_KEY=change-me-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=fastlane.pythonanywhere.com,www.fastlane.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://fastlane.pythonanywhere.com

# Base de données MySQL (PythonAnywhere)
DB_ENGINE=mysql
DB_NAME=fastlane$default
DB_USER=fastlane
DB_PASSWORD=
DB_HOST=fastlane.mysql.pythonanywhere-services.com
DB_PORT=3306
DB_CONN_MAX_AGE=60
